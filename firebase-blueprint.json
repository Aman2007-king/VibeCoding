{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Unique identifier for the user" },
        "email": { "type": "string", "format": "email", "description": "User's email address" },
        "displayName": { "type": "string", "description": "User's display name" },
        "photoURL": { "type": "string", "description": "User's profile picture URL" },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the user account was created" },
        "lastLoginAt": { "type": "string", "format": "date-time", "description": "When the user last logged in" },
        "settings": {
          "type": "object",
          "properties": {
            "theme": { "type": "string", "enum": ["dark", "light", "system"] },
            "fontSize": { "type": "number" }
          }
        }
      },
      "required": ["uid", "email"]
    },
    "Project": {
      "title": "Project",
      "description": "A code project created by the user",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Unique identifier for the project" },
        "ownerId": { "type": "string", "description": "UID of the project owner" },
        "name": { "type": "string", "description": "Project name" },
        "description": { "type": "string", "description": "Project description" },
        "files": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": { "type": "number" },
              "name": { "type": "string" },
              "code": { "type": "string" },
              "language": { "type": "string" },
              "type": { "type": "string" },
              "parentId": { "type": "number" }
            }
          }
        },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "ownerId", "name", "files"]
    },
    "ChatMessage": {
      "title": "ChatMessage",
      "description": "A message in a chat conversation",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "role": { "type": "string", "enum": ["user", "assistant", "system"] },
        "content": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "userId", "role", "content", "timestamp"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profile documents"
    },
    "/projects/{projectId}": {
      "schema": "Project",
      "description": "User projects"
    },
    "/users/{userId}/chats/{chatId}": {
      "schema": "ChatMessage",
      "description": "User chat history"
    }
  }
}
