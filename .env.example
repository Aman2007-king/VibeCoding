# ─────────────────────────────────────────────────────────────────────────
# REQUIRED — the server will refuse to start without these (see server.ts).
# Generate strong values with:  npm run generate-secrets
# ─────────────────────────────────────────────────────────────────────────

# Used to encrypt/decrypt user-saved API keys (Gemini, etc.) at rest.
# Exactly 32 characters used (longer values are truncated, shorter ones
# padded) — `npm run generate-secrets` already produces the right length.
# Changing this after you have stored encrypted keys makes them undecryptable.
ENCRYPTION_KEY=

# Used to sign session cookies. Any reasonably long random string is fine.
SESSION_SECRET=

# ─────────────────────────────────────────────────────────────────────────
# OPTIONAL — features degrade gracefully (with a clear error from the
# relevant endpoint) if these aren't set, rather than failing to boot.
# ─────────────────────────────────────────────────────────────────────────

# GitHub OAuth (sign-in + repo push from the Source Control panel)
# Create at: https://github.com/settings/developers
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
# Must exactly match the callback URL configured on the GitHub OAuth App
GITHUB_REDIRECT_URI=http://localhost:5173/api/auth/github/callback

# Google OAuth (sign-in)
# Create at: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# JDoodle (code execution for languages other than Python/JS — Java, C++, Go, etc.)
# Get credentials at: https://www.jdoodle.com/compiler-api
JDOODLE_CLIENT_ID=
JDOODLE_CLIENT_SECRET=

# Sandboxed execution engine for Python/JS (see server.ts executeSandboxed()).
# Defaults to the free public Piston instance — only set this if you're
# self-hosting your own Piston instance for higher throughput.
# PISTON_API_URL=https://emkc.org/api/v2/piston

# Only needed if your frontend is ever served from a DIFFERENT origin than
# this backend (e.g. frontend on Netlify, backend on Render). Comma-separated.
# Not needed for the default single-service deployment (frontend + backend
# served from this same Express server) — same-origin requests are always
# allowed regardless of this setting. See server.ts Socket.IO CORS config.
# ALLOWED_ORIGINS=https://your-frontend-domain.com,https://another-domain.com

# Standard Node/Express
# NODE_ENV=production
# PORT=3000
